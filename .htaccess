<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # 1. Matikan penambahan slash otomatis pada folder (Mencegah Redirect Loop / Crash)
    DirectorySlash Off

    # 2. Pastikan halaman utama (root) tetap memuat index.html
    RewriteRule ^$ index.html [L]

    # 3. Jika file .html ada, gunakan itu secara diam-diam (contoh: /portfolio -> portfolio.html)
    RewriteCond %{REQUEST_FILENAME}.html -f
    RewriteRule ^(.*)$ $1.html [L]

    # 4. Jika URL adalah sebuah folder, cari index.html di dalamnya (contoh: /journal -> journal/index.html)
    RewriteCond %{REQUEST_FILENAME}/index.html -f
    RewriteRule ^(.*)$ $1/index.html [L]
</IfModule>